# Do not commit real credentials.
# TxLINE devnet free tier. Use the mainnet origin only for a mainnet subscription.
TXLINE_ORIGIN=https://txline-dev.txodds.com
# The service obtains a short-lived guest JWT from TXLINE_ORIGIN at connection time.
TXLINE_API_TOKEN=
# Optional manual overrides. Leave these blank to automatically discover a live/upcoming TxLINE
# fixture, resolve its matching Pascal market, and persist the selected mapping in the journal.
TXLINE_FIXTURE_ID=
# Optional local market label for the resolved feed.
TXLINE_MARKET=
# Pascal public L2 market data does not require an API key.
PASCAL_WS_URL=wss://data.pascal.trade/ws
# Optional known Pascal symbol. The selected TxLINE outcome must still be compatible.
PASCAL_SYMBOL=
EDGERUNNER_CONTROL_TOKEN=replace-for-shared-deployments
